{
  "name": "payment-flow",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prebuild": "npm run clean && npm run prisma:generate",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "prestart": "npm run clean && npm run prisma:generate",
    "start": "nest start",
    "prestart:dev": "npm run clean && npm run prisma:generate",
    "start:dev": "nest start --watch",
    "prestart:debug": "npm run clean && npm run prisma:generate",
    "start:debug": "nest start --debug --watch",
    "prestart:prod": "npm run clean && npm run prisma:generate && npm run build",
    "start:prod": "node dist/main.js",
    "dev": "npx ts-node src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "prisma:migrate": "prisma migrate dev",
    "db:show": "prisma studio",
    "docker:up": "docker compose --env-file .env -f docker/docker-compose.yml up -d --build",
    "docker:down": "docker compose --env-file .env -f docker/docker-compose.yml down",
    "docker:logs": "docker compose --env-file .env -f docker/docker-compose.yml logs -f",
    "docker:ps": "docker compose --env-file .env -f docker/docker-compose.yml ps"
  },
  "keywords": [],
