    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/client": "^6.4.1",
    "@types/uuid": "^8.3.4",
    "axios": "^1.13.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "graphql": "^16.12.0",
    "ioredis": "^5.9.3",
    "pg": "^8.18.0",
    "prisma": "^6.4.1",
